{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "description": "Default build configuration. Requires Ninja generator (apt install ninja-build).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "default-any-generator",
            "displayName": "Default Config (Any Generator)",
            "description": "Default build configuration using system default generator.",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug Config",
            "description": "Debug build configuration",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "default-any-generator",
            "configurePreset": "default-any-generator"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        }
    ]
}
