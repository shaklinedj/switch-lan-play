diff --git a/ldn_mitm/source/lanplay_bridge.hpp b/ldn_mitm/source/lanplay_bridge.hpp
new file mode 100644
--- /dev/null
+++ b/ldn_mitm/source/lanplay_bridge.hpp
@@ -0,0 +1,68 @@
+#pragma once
+
+/**
+ * lanplay_bridge — integration helpers between ldn_mitm and switch-lan-play.
+ *
+ * switch-lan-play writes its runtime state to sdmc:/tmp/lanplay.status
+ * whenever it is active.  This module reads that file so that ldn_mitm can:
+ *
+ *  1. Advertise the VIRTUAL IP (10.13.x.y) instead of the real WiFi IP in
+ *     its NetworkInfo / NodeInfo.  This ensures that station-to-AP TCP
+ *     connections are routed through the relay.
+ *
+ *  2. Send LAN-discovery outbound packets via the private IPC channel
+ *     (127.0.0.1:LDN_IPC_PORT) instead of broadcasting on the LAN.
+ *     switch-lan-play's IPC thread receives them, wraps them as IPv4+UDP,
+ *     and forwards them to the relay server.
+ *
+ *  3. Skip nifmSetLocalNetworkMode(true) when switch-lan-play is active.
+ *     That call disables internet access which would sever the relay UDP
+ *     connection that switch-lan-play depends on.
+ *
+ * All functions cache the status file for ~1 s so repeated calls in the
+ * polling loop are cheap.
+ */
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#include <stdint.h>
+#include <stdbool.h>
+#include <sys/socket.h>
+#include <netinet/in.h>
+
+/** Private loopback IPC port: ldn_mitm → switch-lan-play sysmodule. */
+#define LDN_IPC_PORT 11453
+
+/**
+ * Returns true when sdmc:/tmp/lanplay.status contains "active=1".
+ * Returns false if the file is absent or switch-lan-play is not running.
+ */
+bool lanplay_is_active(void);
+
+/**
+ * Returns the virtual IP in HOST byte order (e.g. 0x0A0D0102 for 10.13.1.2),
+ * or 0 if switch-lan-play is not active / status file missing.
+ */
+uint32_t lanplay_get_virtual_ip(void);
+
+/**
+ * Returns the broadcast address for the virtual /16 subnet in HOST byte order
+ * (10.13.255.255 = 0x0A0DFFFF when switch-lan-play is active), or 0.
+ */
+uint32_t lanplay_get_broadcast(void);
+
+/**
+ * Fills *out with the sockaddr_in for the switch-lan-play IPC socket
+ * (127.0.0.1:LDN_IPC_PORT) so ldn_mitm can sendto() LAN-discovery packets
+ * directly to it.
+ *
+ * Returns true when switch-lan-play is active (and *out was filled),
+ * false otherwise.
+ */
+bool lanplay_get_ipc_sockaddr(struct sockaddr_in *out);
+
+#ifdef __cplusplus
+}
+#endif

diff --git a/ldn_mitm/source/lanplay_bridge.cpp b/ldn_mitm/source/lanplay_bridge.cpp
new file mode 100644
--- /dev/null
+++ b/ldn_mitm/source/lanplay_bridge.cpp
@@ -0,0 +1,117 @@
+/**
+ * lanplay_bridge.cpp — reads switch-lan-play's runtime status file and
+ * exposes the virtual IP / IPC helpers declared in lanplay_bridge.hpp.
+ *
+ * The status file (sdmc:/tmp/lanplay.status) is written by the switch-lan-play
+ * sysmodule every 2 seconds while it is active.  Format:
+ *
+ *   active=1
+ *   error=
+ *   my_ip=10.13.X.Y
+ *   relay=server:11451
+ *   up_pkt=...
+ *   ...
+ *
+ * We parse only "active=" and "my_ip=", cache the result for ~1 s to avoid
+ * hammering the SD card on every poll iteration.
+ */
+
+#include "lanplay_bridge.hpp"
+#include <stdio.h>
+#include <string.h>
+#include <arpa/inet.h>
+#include <switch.h>   /* armGetSystemTick */
+
+/* -------------------------------------------------------------------------
+ * Cache — refreshed at most once per second
+ * ---------------------------------------------------------------------- */
+
+/* Horizon Switch hardware: CPU tick rate = 19,200,000 Hz (19.2 MHz).
+ * One second ≈ 19,200,000 ticks.  We re-read the status file once per second
+ * to keep the information fresh without hammering the SD card. */
+static const u64 CACHE_TICKS = 19200000ULL;
+
+static bool     s_cached      = false;
+static bool     s_active      = false;
+static uint32_t s_virtual_ip  = 0;   /* host byte order */
+static uint32_t s_broadcast   = 0;   /* host byte order */
+static u64      s_last_tick   = 0;
+
+static void refresh_cache(void)
+{
+    u64 now = armGetSystemTick();
+    if (s_cached && (now - s_last_tick) < CACHE_TICKS)
+        return;
+
+    s_last_tick = now;
+    s_cached    = true;
+
+    FILE *f = fopen("sdmc:/tmp/lanplay.status", "r");
+    if (!f) {
+        s_active     = false;
+        s_virtual_ip = 0;
+        s_broadcast  = 0;
+        return;
+    }
+
+    bool     active = false;
+    uint32_t ip     = 0;
+
+    char line[256];
+    while (fgets(line, sizeof(line), f)) {
+        /* Strip trailing newline / carriage return */
+        size_t len = strlen(line);
+        while (len > 0 && (line[len - 1] == '\n' || line[len - 1] == '\r'))
+            line[--len] = '\0';
+
+        if (strcmp(line, "active=1") == 0) {
+            active = true;
+        } else if (strncmp(line, "my_ip=", 6) == 0 && line[6] != '\0') {
+            struct in_addr addr;
+            if (inet_aton(line + 6, &addr) == 1)
+                ip = ntohl(addr.s_addr);
+        }
+    }
+    fclose(f);
+
+    s_active     = active && (ip != 0);
+    s_virtual_ip = s_active ? ip                              : 0;
+    /* Virtual /16 broadcast: keep top two octets, set bottom two to 0xFF */
+    s_broadcast  = s_active ? ((ip & 0xFFFF0000u) | 0xFFFFu) : 0;
+}
+
+/* -------------------------------------------------------------------------
+ * Public API
+ * ---------------------------------------------------------------------- */
+
+bool lanplay_is_active(void)
+{
+    refresh_cache();
+    return s_active;
+}
+
+uint32_t lanplay_get_virtual_ip(void)
+{
+    refresh_cache();
+    return s_virtual_ip;
+}
+
+uint32_t lanplay_get_broadcast(void)
+{
+    refresh_cache();
+    return s_broadcast;
+}
+
+bool lanplay_get_ipc_sockaddr(struct sockaddr_in *out)
+{
+    refresh_cache();
+    if (!s_active)
+        return false;
+
+    memset(out, 0, sizeof(*out));
+    out->sin_family      = AF_INET;
+    /* 127.0.0.1 in network byte order */
+    out->sin_addr.s_addr = htonl(INADDR_LOOPBACK);
+    out->sin_port        = htons(LDN_IPC_PORT);
+    return true;
+}
