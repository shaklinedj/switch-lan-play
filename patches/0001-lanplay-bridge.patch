diff --git a/ldn_mitm/source/lanplay_bridge.hpp b/ldn_mitm/source/lanplay_bridge.hpp
new file mode 100644
--- /dev/null
+++ b/ldn_mitm/source/lanplay_bridge.hpp
@@ -0,0 +1,55 @@
+#pragma once
+/**
+ * lanplay_bridge.hpp — interface between ldn_mitm and switch-lan-play sysmodule.
+ *
+ * switch-lan-play writes sdmc:/tmp/lanplay.status every ~2 seconds.
+ * These helpers read that file (with a ~1 second cache) and expose the
+ * sysmodule's current state to ldn_mitm.
+ *
+ * IPC channel: when switch-lan-play is active, ALL ldn_mitm outbound
+ * LAN-discovery packets (Scan, ScanResp, ...) are sent to the sysmodule's
+ * private loopback socket at 127.0.0.1:LDN_IPC_PORT.  Each message carries
+ * a 4-byte destination IPv4 prefix followed by the LDN protocol payload,
+ * so the sysmodule can correctly build unicast OR broadcast relay frames.
+ */
+
+#include <switch.h>
+#include <netinet/in.h>
+#include <stdint.h>
+#include <stdbool.h>
+
+/* Port that the sysmodule's IPC socket listens on (loopback only) */
+static const uint16_t LDN_IPC_PORT = 11453;
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * lanplay_is_active — returns true if switch-lan-play is currently running
+ * and has a valid virtual IP assigned.
+ */
+bool     lanplay_is_active(void);
+
+/**
+ * lanplay_get_virtual_ip — returns this console's virtual IP (host byte order)
+ * as assigned by switch-lan-play, or 0 if not active.
+ */
+uint32_t lanplay_get_virtual_ip(void);
+
+/**
+ * lanplay_get_broadcast — returns the virtual subnet broadcast address
+ * (10.13.255.255, host byte order) when switch-lan-play is active, or 0.
+ */
+uint32_t lanplay_get_broadcast(void);
+
+/**
+ * lanplay_get_ipc_sockaddr — fills *out with the sysmodule's IPC socket
+ * address (127.0.0.1:LDN_IPC_PORT) when switch-lan-play is active.
+ * Returns true on success, false if not active.
+ */
+bool     lanplay_get_ipc_sockaddr(struct sockaddr_in *out);
+
+#ifdef __cplusplus
+}
+#endif

diff --git a/ldn_mitm/source/lanplay_bridge.cpp b/ldn_mitm/source/lanplay_bridge.cpp
new file mode 100644
--- /dev/null
+++ b/ldn_mitm/source/lanplay_bridge.cpp
@@ -0,0 +1,86 @@
+/**
+ * lanplay_bridge.cpp — reads sdmc:/tmp/lanplay.status and exposes the
+ * switch-lan-play sysmodule state to ldn_mitm.
+ *
+ * The status file is written by switch-lan-play every ~2 seconds:
+ *   active=1
+ *   my_ip=10.13.X.Y
+ *
+ * We cache the parsed result for ~1 second (19 200 000 Switch CPU ticks
+ * at the standard 19.2 MHz ARM PMU clock) to avoid spamming SD card reads.
+ */
+#include "lanplay_bridge.hpp"
+#include <stdio.h>
+#include <string.h>
+#include <arpa/inet.h>
+
+#define STATUS_FILE "sdmc:/tmp/lanplay.status"
+
+/* Cache: refresh after ~1 second (19.2 MHz * 1 s) */
+#define CACHE_TICKS 19200000ULL
+
+struct BridgeState {
+    bool     active;
+    uint32_t virtual_ip; /* host byte order */
+    u64      last_tick;
+};
+
+static BridgeState g_state = { false, 0, 0 };
+
+static void refresh_if_needed(void) {
+    u64 now = armGetSystemTick();
+    if (now - g_state.last_tick < CACHE_TICKS) return;
+
+    g_state.active     = false;
+    g_state.virtual_ip = 0;
+    g_state.last_tick  = now;
+
+    FILE *f = fopen(STATUS_FILE, "r");
+    if (!f) return;
+
+    char line[128];
+    bool saw_active = false;
+    while (fgets(line, sizeof(line), f)) {
+        if (strncmp(line, "active=1", 8) == 0) {
+            saw_active = true;
+        } else if (strncmp(line, "my_ip=", 6) == 0) {
+            char ip_str[32] = {0};
+            if (sscanf(line + 6, "%31s", ip_str) == 1) {
+                struct in_addr a;
+                if (inet_aton(ip_str, &a) == 1) {
+                    /* ntohl: status file IP is human-readable dotted-decimal */
+                    g_state.virtual_ip = ntohl(a.s_addr);
+                }
+            }
+        }
+    }
+    fclose(f);
+    g_state.active = saw_active && (g_state.virtual_ip != 0);
+}
+
+bool lanplay_is_active(void) {
+    refresh_if_needed();
+    return g_state.active;
+}
+
+uint32_t lanplay_get_virtual_ip(void) {
+    refresh_if_needed();
+    return g_state.active ? g_state.virtual_ip : 0;
+}
+
+uint32_t lanplay_get_broadcast(void) {
+    refresh_if_needed();
+    if (!g_state.active) return 0;
+    /* Virtual subnet is 10.13.0.0/16; broadcast = 10.13.255.255 */
+    return (10u << 24) | (13u << 16) | 0xFFFFu;
+}
+
+bool lanplay_get_ipc_sockaddr(struct sockaddr_in *out) {
+    refresh_if_needed();
+    if (!g_state.active) return false;
+    memset(out, 0, sizeof(*out));
+    out->sin_family      = AF_INET;
+    out->sin_addr.s_addr = htonl(INADDR_LOOPBACK); /* 127.0.0.1 */
+    out->sin_port        = htons(LDN_IPC_PORT);
+    return true;
+}
